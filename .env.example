# Configuration API Pokémon Predictor
# À copier en .env.local et adapter selon votre environnement

# Environnement
ENVIRONMENT=development
DEBUG=True

# API Configuration
API_TITLE=Pokémon Battle Predictor
API_VERSION=1.0.0
API_DESCRIPTION=Prédiction du taux de victoire Pokémon basée sur les statistiques

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True
WORKERS=1

# Modèle
MODEL_PATH=modele/modele_pokemon.mod
MODEL_VERSION=1.0.0

# Security
API_KEY_ENABLED=False
API_KEY=your-secret-api-key-here
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/api.log

# Database (pour monitoring)
DATABASE_URL=sqlite:///./predictions.db

# Features
ENABLE_BATCH_PREDICT=True
ENABLE_COMPARE=False
ENABLE_SWAGGER_UI=True
ENABLE_REDOC=True

# Limits
MAX_BATCH_SIZE=100
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_PERIOD=60

# Timeouts
PREDICTION_TIMEOUT_MS=5000

# Cache
REDIS_ENABLED=False
REDIS_URL=redis://localhost:6379

# Monitoring
PROMETHEUS_ENABLED=False
PROMETHEUS_PORT=8001
